# Riot API key for the offline build aggregator (scripts/aggregate-builds.mjs).
# Get a dev key at https://developer.riotgames.com (regenerates every 24h).
# Copy this file to .env and fill it in. .env is gitignored.
RIOT_API_KEY=

# Optional: min ms between Riot requests (default 1300 keeps a dev key under
# its 100-requests / 2-minute limit). Lower it only with a production key.
# RIOT_MIN_INTERVAL_MS=1300
